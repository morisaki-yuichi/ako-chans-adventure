source "https://rubygems.org"

# Pin to the exact Jekyll + plugin versions that GitHub Pages runs,
# so local previews match production. See:
# https://pages.github.com/versions/
gem "github-pages", group: :jekyll_plugins

# Ruby 3.0+ no longer bundles webrick, which `jekyll serve` needs locally.
gem "webrick", "~> 1.8"
